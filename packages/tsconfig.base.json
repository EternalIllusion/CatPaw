{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@eterill/catpaw-common": ["./common/src/index.ts"],
      "@eterill/catpaw-common/*": ["./common/src/*"],
      "@eterill/catpaw-element": ["./element/src/index.ts"],
      "@eterill/catpaw-element/*": ["./element/src/*"],
      "@eterill/catpaw": ["./excalidraw/index.tsx"],
      "@eterill/catpaw/*": ["./excalidraw/*"],
      "@eterill/catpaw-laser-pointer": ["./laser-pointer/src/index.ts"],
      "@eterill/catpaw-laser-pointer/*": ["./laser-pointer/src/*"],
      "@eterill/catpaw-math": ["./math/src/index.ts"],
      "@eterill/catpaw-math/*": ["./math/src/*"],
      "@eterill/catpaw-utils": ["./utils/src/index.ts"],
      "@eterill/catpaw-utils/*": ["./utils/src/*"],
      "@eterill/catpaw-fractional-indexing": ["./fractional-indexing/src/index.ts"],
      "@eterill/catpaw-fractional-indexing/*": ["./fractional-indexing/src/*"]
    }
  }
}
